      "versionNonce": 1449606906,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773672050881,
      "link": null,
      "locked": false,
      "text": "Essentially you write a script for a human (maybe AI soon?) to go through\nand validate functionality.\n\nOften you'll deploy to a test server and then have QA teams go through\nthat and validate all the edge cases etc.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Essentially you write a script for a human (maybe AI soon?) to go through\nand validate functionality.\n\nOften you'll deploy to a test server and then have QA teams go through\nthat and validate all the edge cases etc.",
      "autoResize": true,
      "lineHeight": 1.25
    }
