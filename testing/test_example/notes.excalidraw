    },
    {
      "id": "dimqHLQLNg4qK3Rho7ly2",
      "type": "text",
      "x": -930.5413763953538,
      "y": 858.4872627662343,
      "width": 680.1594848632812,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 1768348154,
      "version": 385,
      "versionNonce": 381391418,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773671609696,
      "link": null,
      "locked": false,
      "text": "It is the best way to develop code (scientifically)\n\nBut there are some caveats:\n- You need to know what you're making\n- It takes time up front for things that are not features\n (Managers don't like this generally)\n- It's not good for frontend (testing in general is hard for frontend)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is the best way to develop code (scientifically)\n\nBut there are some caveats:\n- You need to know what you're making\n- It takes time up front for things that are not features\n (Managers don't like this generally)\n- It's not good for frontend (testing in general is hard for frontend)",
      "autoResize": true,
      "lineHeight": 1.25
    },
