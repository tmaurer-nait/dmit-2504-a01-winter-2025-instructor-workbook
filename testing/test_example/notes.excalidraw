      "isDeleted": false,
      "boundElements": null,
      "updated": 1773671535954,
      "link": null,
      "locked": false,
      "text": "Method Sum(a,b)\n\n1. Test Sum(1,1) = 2\n2. Test Sum(0,1) = 1\n3. Test Sum(0,0) = 0\n4. Test Sum(-1,-1) = -2\n...\n10. All tests are written\n    so we write the Sum() code",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Method Sum(a,b)\n\n1. Test Sum(1,1) = 2\n2. Test Sum(0,1) = 1\n3. Test Sum(0,0) = 0\n4. Test Sum(-1,-1) = -2\n...\n10. All tests are written\n    so we write the Sum() code",
      "autoResize": true,
      "lineHeight": 1.25
    },
