      "text": "UNIT TESTING SHOULD VALIDATE\nBEHAVIOUR NOT IMPLEMENTATION",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UNIT TESTING SHOULD VALIDATE\nBEHAVIOUR NOT IMPLEMENTATION",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cfYcQejCHyoXtm0LvEzTP",
      "type": "text",
      "x": -982.7412337822791,
      "y": 1316.864190135047,
      "width": 751.6795654296875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "av",
      "roundness": null,
      "seed": 851010854,
      "version": 306,
      "versionNonce": 895250214,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773671836720,
      "link": null,
      "locked": false,
      "text": "As far as the tests are concerned, the code they are testing is a black box.\nThey should not care about how it is accomplishing the goal. They only\ncare about what is being output.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "As far as the tests are concerned, the code they are testing is a black box.\nThey should not care about how it is accomplishing the goal. They only\ncare about what is being output.",
      "autoResize": true,
      "lineHeight": 1.25
    },
