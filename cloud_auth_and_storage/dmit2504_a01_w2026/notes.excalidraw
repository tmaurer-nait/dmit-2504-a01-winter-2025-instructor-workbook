    {
      "id": "jHWHdCAElk_Clhj_89Ek3",
      "type": "text",
      "x": 2135.0049276498553,
      "y": 837.4122955787697,
      "width": 580.7595825195312,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aw",
      "roundness": null,
      "seed": 1718883747,
      "version": 408,
      "versionNonce": 444267245,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772464905831,
      "link": null,
      "locked": false,
      "text": "Sometimes we need to protect certain pages\nfrom unauthorized user access.\n\nWhile the backend secures our data, the frontend\ncannot show \"unauthorized\" data and so would break\nif you try to access pages that need it without\nauthorization.\n\nTo protect the routes we add a check in onGenerateRoute",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sometimes we need to protect certain pages\nfrom unauthorized user access.\n\nWhile the backend secures our data, the frontend\ncannot show \"unauthorized\" data and so would break\nif you try to access pages that need it without\nauthorization.\n\nTo protect the routes we add a check in onGenerateRoute",
      "autoResize": true,
      "lineHeight": 1.25
    },
